<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.medical.mapper.EmployeeMapper">
    <insert id="AddEmployeeByRole" useGeneratedKeys="true" keyProperty="EmployeeId">
        insert into employees (Role) values (#{role})
    </insert>
    <update id="update">
        UPDATE employees
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="position != null and position != ''">
                position = #{position},
            </if>
            <if test="department != null and department != ''">
                department = #{department},
            </if>
            <if test="email != null and email != ''">
                email = #{email},
            </if>
            <if test="phone != null and phone != ''">
                phone = #{phone},
            </if>
            <if test="role != null and role != ''">
                role = #{role},
            </if>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
            <if test="gender != null and gender != ''">
                gender = #{gender},
            </if>
            <if test="age != null">
                age = #{age}
            </if>
        </set>
        <where>
            employeeId = #{employeeId}
        </where>
    </update>
    <update id="changePassword">
        update employees set Password = #{newPassword} where EmployeeID = #{employeeId} and Password = #{oldPassword};
    </update>

    <select id="selectBySearch" resultType="com.medical.entity.Employee">
        select * from employees
        <where>
            name is not null
            <if test="name != null and name != ''">
             and name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="department != null and department != ''">
             AND department = #{department}
            </if>
        </where>
    </select>
</mapper>